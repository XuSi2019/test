{
  "name": "performance-optimized-app",
  "version": "1.0.0",
  "description": "Performance-optimized web application template",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "analyze": "npm run build && npx vite-bundle-analyzer dist",
    "lighthouse": "lhci autorun",
    "size-check": "bundlesize",
    "perf-test": "npm run build && npm run lighthouse && npm run size-check"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "web-vitals": "^3.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.26",
    "@types/react-dom": "^18.0.9",
    "@vitejs/plugin-react": "^3.0.0",
    "vite": "^4.0.0",
    "vite-bundle-analyzer": "^0.7.0",
    "vite-plugin-pwa": "^0.14.1",
    "@lhci/cli": "^0.12.0",
    "bundlesize": "^0.18.1",
    "terser": "^5.16.0",
    "rollup-plugin-visualizer": "^5.9.0"
  },
  "bundlesize": [
    {
      "path": "./dist/assets/*.js",
      "maxSize": "250 kB",
      "compression": "gzip"
    },
    {
      "path": "./dist/assets/*.css",
      "maxSize": "50 kB",
      "compression": "gzip"
    }
  ],
  "engines": {
    "node": ">=16",
    "npm": ">=8"
  }
}